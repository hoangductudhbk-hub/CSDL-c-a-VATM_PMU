# Copy file này thành worker.env và điền thông tin

# Tài khoản Firebase (email/password dùng để đăng nhập app)
EMAIL=your@email.com
PASSWORD=your_password

# (Tuỳ chọn) Nếu ABBYY không tự tìm được
ABBYY_PATH=C:\Program Files\ABBYY FineReader PDF 16\FineCmd.exe

# (Tuỳ chọn) GitHub token nếu chưa có trong .env.local
# GH_TOKEN=ghp_xxx

# Poll interval (ms), mặc định 15000 = 15 giây
# POLL_INTERVAL=15000
